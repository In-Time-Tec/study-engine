{
  "name": "study-engine",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "study-engine-ui"
  ],
  "scripts": {
    "dev": "node boot.mjs",
    "typecheck": "npm run typecheck --workspace study-engine-ui",
